# Raydium-LP1 local secrets/settings file.
# Copy this to .env with scripts\setup_wizard.ps1. Never commit your real .env.
RAYDIUM_API_BASE=https://api-v3.raydium.io
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Optional: comma-separated fallback RPCs. Private provider URLs with API keys belong here, not in GitHub.
SOLANA_RPC_URLS=https://solana-rpc.publicnode.com,https://solana.drpc.org

# --- Wallet (DRY-RUN ONLY in this build) ---------------------------------
# Your Solana wallet public address. Required for wallet-aware features
# (balance, position capacity, emergency close planning).
WALLET_ADDRESS=
# Your wallet private key. Keep this in .env only and NEVER commit it.
# Dry-run builds will not sign or send transactions with this key.
WALLET_PRIVATE_KEY=
