# =============================================================================
# Raydium-LP1 — local secrets (copy to ".env" at repo root; NEVER commit .env)
# =============================================================================
#
# Production checklist (before any live signing exists in this repo):
#   1) Use a dedicated hot wallet with limited SOL, not your cold storage.
#   2) Keep WALLET_PRIVATE_KEY only here and in OS secret stores — not in GitHub, not in screenshots.
#   3) Prefer paid RPC endpoints for reliable reads and future sends.
#   4) Keep dry_run=true in config/settings.json until you deliberately enable live code paths.
#
# This build remains DRY-RUN for swap/LP execution; keys are loaded for balance,
# capacity math, and future signing hooks.

# --- Raydium / HTTP (optional overrides) -------------------------------------
RAYDIUM_API_BASE=https://api-v3.raydium.io

# --- Solana RPC -------------------------------------------------------------
# Primary RPC (read + future write). Use a provider URL with your API key if applicable.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Optional comma- or semicolon-separated fallbacks (tried in order after the primary).
SOLANA_RPC_URLS=https://solana-rpc.publicnode.com,https://solana.drpc.org

# --- Wallet (required for balance / max_positions; signing not active here) -
# Base58 public address (44 chars typical).
WALLET_ADDRESS=
# Base58-encoded secret key (64-byte keypair) OR JSON array export — same as many Solana CLIs expect.
# Leave empty for read-only address-only runs.
WALLET_PRIVATE_KEY=

# --- Scanner overrides (optional) -------------------------------------------
# Force a strategy preset name for one process: conservative | moderate | aggressive | degen | custom
# RAYDIUM_LP1_STRATEGY=

# --- Live trading gate (future; keep false until you run audited live code) --
# When live execution lands, it MUST require explicit operator intent — never default true.
RAYDIUM_LP1_LIVE_TRADING=false

# --- Verdict mirror log (optional) ------------------------------------------
# RAYDIUM_LP1_VERDICT_LOG_PLAIN=1   # if set, Python strips ANSI from reports/verdict_stream.log
