{
  "dry_run": true,
  "min_apr": 999.99,
  "apr_field": "apr24h",
  "raydium_api_base": "https://api-v3.raydium.io",
  "pool_type": "all",
  "sort_type": "desc",
  "page_size": 100,
  "pages": 1,
  "min_liquidity_usd": 1000,
  "min_volume_24h_usd": 100,
  "max_position_usd": 25,
  "allowed_quote_symbols": ["SOL", "USDC", "USDT", "USD1"],
  "blocked_token_symbols": [],
  "blocked_mints": [],
  "require_pool_id": true,
  "solana_rpc_urls": [],

  "_comment_survival_runway": "How long the pool must look like it can keep paying. See SETTINGS.md.",
  "survival_runway": {
    "enabled": true,
    "target_survival_days": 5,
    "min_tvl_multiple_of_position": 200,
    "min_daily_volume_pct_of_tvl": 5.0,
    "require_active_week": true
  },

  "_comment_quote_only_entry": "Never buy the unknown token at entry. Only deposit your safe quotes.",
  "quote_only_entry": {
    "enabled": true,
    "allowed_quote_symbols": ["SOL", "USDC", "USDT", "USD1"],
    "require_concentrated_pool": false,
    "allow_quote_quote_pools": true
  },

  "_comment_honeypot_guard": "Refuse pools whose base token has sell-tax / freeze / transfer-hook traps.",
  "honeypot_guard": {
    "enabled": true,
    "max_sell_tax_percent": 30.0,
    "reject_if_freeze_authority_set": true,
    "reject_if_transfer_hook_set": true,
    "reject_if_permanent_delegate_set": true,
    "allowed_freeze_authority_mints": [
      "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v",
      "Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB"
    ],
    "fail_open_when_no_rpc": false,
    "rpc_timeout_seconds": 8.0
  },

  "_comment_pool_age_guard": "Reject pools too young to trust (no history) or too old to have alpha.",
  "pool_age_guard": {
    "enabled": true,
    "min_age_minutes": 60,
    "max_age_days": 0,
    "fail_open_when_unknown": false
  },

  "_comment_mint_authority_guard": "Reject base tokens whose mint authority can still mint unlimited supply.",
  "mint_authority_guard": {
    "enabled": true,
    "reject_if_mint_authority_set": true,
    "allowed_mint_authority_mints": [
      "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v",
      "Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB"
    ],
    "fail_open_when_no_rpc": false
  },

  "_comment_lp_lock_guard": "Require a high fraction of LP supply burned/locked so the creator cannot pull liquidity.",
  "lp_lock_guard": {
    "enabled": true,
    "min_locked_or_burned_pct": 90.0,
    "apply_to_concentrated_pools": false,
    "fail_open_when_no_rpc": false,
    "rpc_timeout_seconds": 8.0
  },

  "_comment_price_impact_guard": "Estimate slippage on a max_position_usd entry; reject above this percent.",
  "price_impact_guard": {
    "enabled": true,
    "max_impact_percent": 1.0,
    "quote_side_fraction": 0.5
  },

  "_comment_fee_apr_floor": "Require fee-only APR floor so headline APR isn't carried by farm rewards alone.",
  "fee_apr_floor": {
    "enabled": true,
    "min_fee_apr_percent": 30.0
  },

  "_comment_rpc_health_gate": "Refuse to scan unless at least N configured Solana RPCs answer getHealth.",
  "rpc_health_gate": {
    "enabled": true,
    "min_healthy_rpcs": 1,
    "require_when_no_rpc_configured": false
  }
}
